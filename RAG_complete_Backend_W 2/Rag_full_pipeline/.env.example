# ═══════════════════════════════════════════════════════════════════════════════
#  Virchow Ingestion Pipeline — example environment
#  Copy to .env and fill in secrets. `.env` is gitignored.
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL (REQUIRED) ─────────────────────────────────────────────────────
PG_HOST=192.168.10.10
PG_PORT=5433
PG_DATABASE=virchow_dev
PG_USER=postgres
PG_PASSWORD=                   # REQUIRED — service refuses to start without it

# ── System defaults (used when the API caller omits dept/user) ────────────────
SYSTEM_DEPT_ID=00000000-0000-0000-0000-000000000001
SYSTEM_USER_ID=74309524-a17b-4a99-bebb-ad822f6fe3a6

# ── Redis (Docker) ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── RabbitMQ (Docker) ─────────────────────────────────────────────────────────
RABBIT_HOST=rabbitmq
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASS=guest
RABBIT_VHOST=/

# ── DotsOCR (VLM layout engine) ───────────────────────────────────────────────
DOTS_OCR_USE_HF=true
DOTS_OCR_MODEL=rednote-hilab/dots.ocr
DOTS_OCR_WEIGHTS=/app/weights/DotsOCR
DOTS_OCR_PROMPT_MODE=prompt_layout_all_en
DOTS_OCR_FITZ_PREPROCESS=true
DOTS_OCR_IP=localhost
DOTS_OCR_PORT=8001

# ── Embedding (native MPS on macOS; "cpu" or "cuda" elsewhere) ────────────────
EMBEDDING_DEVICE=mps
EMBEDDING_BATCH_SIZE=256

# ── SeaweedFS (raw PDF + processed JSON) ──────────────────────────────────────
SEAWEEDFS_MASTER_URL=http://192.168.10.10:9333
SEAWEEDFS_FILER_URL=http://192.168.10.10:8889
SEAWEEDFS_S3_ENDPOINT=http://192.168.10.10:8333
SEAWEEDFS_BUCKET=rag-docs
SEAWEEDFS_ACCESS_KEY=anykey
SEAWEEDFS_SECRET_KEY=anysecret

# ── Chunking (scanned-only corpus — tuned for mxbai-embed-large) ──────────────
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# ── Entity extraction (AI-5) — local Ollama ───────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_EXTRACTION_MODEL=qwen2.5:14b-instruct
OLLAMA_TIMEOUT_SEC=25
EXTRACTION_MAX_CHARS=2000

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
UPLOAD_WORKERS=3
