.idea/
.vscode/
*.swp
*.swo

# ── Uploads & Data ────────────────────────────────────────────────────────────
uploads/
data/
/tmp/

# ── Model caches (large binary files) ────────────────────────────────────────
.cache/
*.cache/

# ── Docker data volumes (local bind-mounts if used) ──────────────────────────
rag_db_data/
redis_data/
rabbit_data/
seaweedfs_*/

